# ─── LLM Provider ──────────────────────────────────────────
# Choose "openai" or "gemini"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Gemini
GEMINI_API_KEY= ....
GEMINI_MODEL=gemini-3-flash

# ─── Database ───────────────────────────────────────────────
# Target read-only DB (where user data lives, for SQL execution)
DATABASE_URL=postgresql+asyncpg://readonly_user:password@localhost:5432/mydb

# Internal log DB (stores query history, metrics)
LOG_DATABASE_URL=sqlite+aiosqlite:///./nl2sql_logs.db

# ─── Embedding Model ────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
TOP_K_TABLES=5

# ─── Execution Limits ───────────────────────────────────────
QUERY_ROW_LIMIT=1000
QUERY_TIMEOUT_SECONDS=10
MAX_CORRECTION_RETRIES=2

# ─── LLM Generation ─────────────────────────────────────────
LLM_TEMPERATURE=0.1
CONFIDENCE_THRESHOLD=0.6

# ─── API ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Frontend ───────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
